# =============================================================================
# My-First-Bot Environment Configuration
# =============================================================================
# Copy this to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
# =============================================================================

# --- Logging ---
RUST_LOG=info                    # Log level: trace, debug, info, warn, error

# --- Polymarket CLOB API Credentials ---
# Get these from https://polymarket.com (Settings → API Keys)
POLYMARKET_API_KEY=              # Your CLOB API key
POLYMARKET_API_SECRET=           # Your CLOB API secret
POLYMARKET_PRIVATE_KEY=          # Ethereum private key for ECDSA signing (hex, no 0x prefix)

# --- Bot Mode ---
BOT_MODE=paper                   # "paper" (simulated) or "live" (real money)
AUTO_START=false                 # Start trading automatically on boot (true/false)

# --- API Server ---
API_PORT=4200                    # REST API port
API_AUTH_TOKEN=                  # Bearer token for /start, /stop, /kill endpoints

# --- Strategy ---
STRATEGY_PROFILE=fair-value      # Which strategy profile to run
STRATEGY_SERVICE_URL=http://localhost:8100  # Python strategy service URL

# --- Risk Management ---
BANKROLL=100                     # Total bankroll in USD
CRYPTO_EDGE_THRESHOLD=0.04      # Minimum edge to trade (4% = covers ~2% fee each side)
KELLY_FRACTION=0.25              # Base Kelly fraction for position sizing
MAX_POSITIONS=6                  # Maximum concurrent positions
MAX_EXPOSURE_PCT=1.5             # Maximum total exposure as multiple of bankroll
MAX_DRAWDOWN_PCT=0.25            # Circuit breaker: stop trading at 25% drawdown
MAX_SAME_DIRECTION=3             # Max positions in same direction (Q14: cross-asset correlation 62.8%)
MAX_SAME_DIRECTION_PCT=0.6       # Max same-direction exposure as fraction of bankroll

# --- Entry Price Bounds ---
MIN_ENTRY_PRICE=0.12             # Reject tokens priced below 12% (too unlikely)
MAX_ENTRY_PRICE=0.88             # Reject tokens priced above 88% (too expensive, low payout)

# --- Data Hub ---
DATA_HUB_URL=http://localhost:4201  # Data hub service URL (if running separately)

# --- Trading Fees ---
TRADING_FEE_BPS=200              # Trading fee in basis points (200 = 2%)
